{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "plugins": ["@nestjs/swagger"],
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../generated/prisma/package.json",
        "outDir": "./dist/generated",
        "watchAssets": true
      }
    ]
  }
}
